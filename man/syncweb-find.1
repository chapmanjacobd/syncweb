.ie \n(.g .ds Aq \(aq
.el .ds Aq '
.TH find 1  "find " 
.SH NAME
find \- Search local files
.SH SYNOPSIS
\fBfind\fR [\fB\-\-kind\fR] [\fB\-\-max\-depth\fR] [\fB\-\-min\-size\fR] [\fB\-\-max\-size\fR] [\fB\-\-extension\fR] [\fB\-\-type\fR] [\fB\-\-threads\fR] [\fB\-h\fR|\fB\-\-help\fR] <\fIPATTERN\fR> [\fIPATH\fR] 
.SH DESCRIPTION
Search local files
.SH OPTIONS
.TP
\fB\-\-kind\fR \fI<KIND>\fR [default: glob]

.br
\fIPossible values:\fR
.RS 14
.IP \(bu 2
exact
.IP \(bu 2
glob
.IP \(bu 2
regex
.RE
.TP
\fB\-\-max\-depth\fR \fI<MAX_DEPTH>\fR

.TP
\fB\-\-min\-size\fR \fI<MIN_SIZE>\fR

.TP
\fB\-\-max\-size\fR \fI<MAX_SIZE>\fR

.TP
\fB\-\-extension\fR \fI<EXTENSION>\fR

.TP
\fB\-\-type\fR \fI<FILE_TYPE>\fR

.br
\fIPossible values:\fR
.RS 14
.IP \(bu 2
f
.IP \(bu 2
d
.IP \(bu 2
l
.RE
.TP
\fB\-\-threads\fR \fI<THREADS>\fR [default: 0]
Scanner threads (1 disables parallelism, 0 uses all available CPUs)
.TP
\fB\-h\fR, \fB\-\-help\fR
Print help
.TP
<\fIPATTERN\fR>

.TP
[\fIPATH\fR] [default: .]

